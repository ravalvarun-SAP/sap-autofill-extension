{
  "manifest_version": 3,
  "name": "SAP SuccessFactors AutoFill",
  "version": "1.0.0",
  "description": "Automatically fills SAP SuccessFactors job application forms with your profile data.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://career5.successfactors.eu/*",
    "https://*.successfactors.eu/*",
    "https://*.successfactors.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://career5.successfactors.eu/*",
        "https://*.successfactors.eu/*",
        "https://*.successfactors.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
